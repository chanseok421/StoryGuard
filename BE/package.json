{
  "name": "storyguard-be",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:secrets": "dotenv -e C:\\Secrets\\storyguard.env -- tsx watch src/server.ts",
    "dev:secrets:win": "dotenv -e C:\\Secrets\\storyguard.env -- tsx watch src/server.ts",
    "dev:secrets:mac": "dotenv -e ~/Secrets/storyguard.env -- tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "start:secrets": "dotenv -e C:\\Secrets\\storyguard.env -- node dist/server.js",
    "start:secrets:win": "dotenv -e C:\\Secrets\\storyguard.env -- node dist/server.js",
    "start:secrets:mac": "dotenv -e ~/Secrets/storyguard.env -- node dist/server.js",
    "test": "npm run test:logging && npm run test:graph && npm run test:rag && node --test src/graph/mockResultContract.test.mjs src/graph/runStoryAnalysis.test.mjs src/rag/retrieveEvidence.test.mjs",
    "test:logging": "tsx src/shared/logger.test.ts",
    "test:graph": "tsx src/graph/validateGraphAnalysisResult.test.ts && tsx src/graph/buildStoryAnalysisPrompt.test.ts && tsx src/graph/runStoryAnalysis.provider.test.ts",
    "test:rag": "tsx src/rag/chunk-settings.test.ts && tsx src/rag/keyword-retriever.test.ts && tsx src/rag/embedding-retriever.test.ts && tsx src/rag/embeddingRetrieveEvidence.test.ts && tsx src/rag/retrieveEvidenceFromVectorStore.test.ts",
    "eval:embedding": "node --import tsx --env-file-if-exists=.env src/rag/embedding-retriever.live.ts",
    "eval:compare": "node --import tsx --env-file-if-exists=.env src/rag/compare-embeddings.live.ts",
    "demo:evidence": "node --import tsx --env-file-if-exists=.env src/rag/embeddingRetrieveEvidence.live.ts",
    "spike:pipeline": "node --import tsx --env-file-if-exists=.env src/rag/pipeline-spike.live.ts",
    "smoke:deepagent": "dotenv -e C:\\Secrets\\storyguard.env -- tsx src/graph/deepagent-smoke.live.ts",
    "smoke:deepagent:mac": "dotenv -e ~/Secrets/storyguard.env -- tsx src/graph/deepagent-smoke.live.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@langchain/classic": "^1.0.36",
    "@langchain/core": "^1.2.0",
    "@langchain/langgraph": "^1.4.6",
    "@langchain/ollama": "^1.3.0",
    "@langchain/openai": "^1.5.1",
    "@qdrant/js-client-rest": "^1.18.0",
    "@supabase/supabase-js": "^2.108.2",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "deepagents": "^1.10.5",
    "express": "^4.19.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.10",
    "dotenv-cli": "^11.0.0",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  }
}
