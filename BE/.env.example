OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
LOG_LEVEL=info
AI_ANALYSIS_PROVIDER=mock
GROQ_API_KEY=
GROQ_ANALYSIS_MODEL=openai/gpt-oss-120b
# deepagent provider. Backend: openai | groq (auto-detected from keys, openai first).
# OpenAI default model is gpt-4o (multi-agent needs a strong model; not OPENAI_ANALYSIS_MODEL).
DEEPAGENT_BACKEND=
DEEPAGENT_MODEL=
DEEPAGENT_TIMEOUT_MS=300000
# LLM call throttle (calls/sec) so one multi-agent run stays under low TPM tiers.
# Default 0.1 (1 per 10s) completes on OpenAI tier-1 gpt-4o (30k TPM). Raise on higher tiers.
DEEPAGENT_REQUESTS_PER_SECOND=
