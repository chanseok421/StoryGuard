OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
LOG_LEVEL=info
AI_ANALYSIS_PROVIDER=mock
GROQ_API_KEY=
GROQ_ANALYSIS_MODEL=openai/gpt-oss-120b
# deepagent provider. Backend: openai | groq (auto-detected from keys, openai first).
# OpenAI default model is gpt-4o (multi-agent needs a strong model; not OPENAI_ANALYSIS_MODEL).
DEEPAGENT_BACKEND=
DEEPAGENT_MODEL=
DEEPAGENT_TIMEOUT_MS=180000
