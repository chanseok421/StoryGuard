PORT=4000
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
COOKIE_SECURE=false
SESSION_COOKIE_NAME=storyguard_session
CORS_ORIGIN=http://localhost:5173
LOG_LEVEL=info

# AI analysis provider: mock | groq | ollama
AI_ANALYSIS_PROVIDER=mock
AI_ANALYSIS_TIMEOUT_MS=20000
GROQ_API_KEY=
GROQ_ANALYSIS_MODEL=openai/gpt-oss-120b
GROQ_API_BASE_URL=https://api.groq.com/openai/v1
OLLAMA_ANALYSIS_MODEL=gpt-oss:20b

# RAG / VectorDB
VECTOR_STORE=qdrant
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=
QDRANT_COLLECTION=document_chunks
QDRANT_VECTOR_SIZE=1024

# 임베딩(기본 Ollama bge-m3, 1024차원). openai로 바꾸면 QDRANT_VECTOR_SIZE도 맞출 것
EMBEDDING_PROVIDER=ollama
OLLAMA_EMBEDDING_MODEL=bge-m3
# 로컬 실행은 비워두면 localhost:11434. 컨테이너에서 호스트 Ollama를 쓸 땐:
# OLLAMA_BASE_URL=http://host.docker.internal:11434

# VECTOR_STORE 선택지: qdrant(기본) | pgvector | memory
