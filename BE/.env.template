PORT=4000
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
COOKIE_SECURE=false
SESSION_COOKIE_NAME=storyguard_session
CORS_ORIGIN=http://localhost:5173
LOG_LEVEL=info

# AI analysis provider: mock | groq | ollama | openai | deepagent
AI_ANALYSIS_PROVIDER=mock
AI_ANALYSIS_TIMEOUT_MS=20000
GROQ_API_KEY=
GROQ_ANALYSIS_MODEL=openai/gpt-oss-120b
GROQ_API_BASE_URL=https://api.groq.com/openai/v1
OLLAMA_ANALYSIS_MODEL=gpt-oss:20b

# Deep Agent (LangGraph 기반). AI_ANALYSIS_PROVIDER=deepagent 일 때 사용.
# 백엔드: openai | groq (미설정 시 키가 있는 쪽 자동 선택, openai 우선).
#  - openai → OPENAI_API_KEY / OPENAI_ANALYSIS_MODEL(기본 gpt-4o-mini) / OPENAI_API_BASE_URL 재사용
#  - groq   → GROQ_API_KEY / GROQ_ANALYSIS_MODEL / GROQ_API_BASE_URL 재사용
# DEEPAGENT_MODEL 을 지정하면 백엔드 기본 모델 대신 그 모델을 쓴다.
DEEPAGENT_BACKEND=
DEEPAGENT_MODEL=
DEEPAGENT_TIMEOUT_MS=90000

# RAG / VectorDB
VECTOR_STORE=qdrant
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=
QDRANT_COLLECTION=document_chunks
QDRANT_VECTOR_SIZE=1024

# 임베딩(기본 Ollama bge-m3, 1024차원). openai로 바꾸면 QDRANT_VECTOR_SIZE도 맞출 것
EMBEDDING_PROVIDER=ollama
OLLAMA_EMBEDDING_MODEL=bge-m3
# 로컬 실행은 비워두면 localhost:11434. 컨테이너에서 호스트 Ollama를 쓸 땐:
# OLLAMA_BASE_URL=http://host.docker.internal:11434

# VECTOR_STORE 선택지: qdrant(기본) | pgvector | memory
